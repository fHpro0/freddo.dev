---
import { getCollection } from 'astro:content'
import DefaultLayout from '../layouts/DefaultLayout.astro'
import ReadsFeed, { type FeedItem } from '../components/ReadsFeed.astro'

const allPosts = await getCollection('post', ({ data }) => !data.draft)
allPosts.sort((a, b) => (b.data.publishDate?.getTime() ?? 0) - (a.data.publishDate?.getTime() ?? 0))

const langColors: Record<string, string> = {
  TypeScript: '#3178c6',
  JavaScript: '#f7df1e',
  Python: '#3572a5',
  PHP: '#777bb4',
  Vue: '#42b883',
  Dart: '#00b4ab',
  HTML: '#e34c26',
  CSS: '#563d7c',
  SCSS: '#c6538c',
  Shell: '#89e051',
  Astro: '#ff5a03',
  Go: '#00add8',
  Rust: '#dea584',
}

let projects: any[] = []
try {
  const res = await fetch(
    'https://api.github.com/users/fHpro0/repos?sort=pushed&per_page=20&type=owner',
    { headers: { 'User-Agent': 'freddo.dev/1.0' } }
  )
  if (res.ok) {
    const repos: any[] = await res.json()
    projects = repos.filter((r) => !r.fork && r.description && r.name !== 'fHpro0')
  }
} catch {}

if (projects.length === 0) {
  projects = [
    {
      name: 'freddo.dev',
      description: 'My personal portfolio built with Astro, Tailwind CSS, and SCSS. Dark neon aesthetic with ASCII canvas animations.',
      html_url: 'https://github.com/fHpro0/freddo.dev',
      pushed_at: '2024-06-01T00:00:00Z',
      language: 'Astro',
      stargazers_count: 0,
    },
    {
      name: 'claude-code-config',
      description: 'Personal Claude Code configuration — skills, hooks, caveman mode, and persistent memory setup.',
      html_url: 'https://github.com/fHpro0',
      pushed_at: '2024-05-15T00:00:00Z',
      language: 'TypeScript',
      stargazers_count: 0,
    },
    {
      name: 'vue-component-kit',
      description: 'Reusable Vue 3 component library with TypeScript, composables, and Tailwind CSS variants.',
      html_url: 'https://github.com/fHpro0',
      pushed_at: '2024-04-20T00:00:00Z',
      language: 'Vue',
      stargazers_count: 0,
    },
    {
      name: 'hono-api-starter',
      description: 'Minimal Hono + Bun API starter with Drizzle ORM, SQLite, and full TypeScript types.',
      html_url: 'https://github.com/fHpro0',
      pushed_at: '2024-03-10T00:00:00Z',
      language: 'TypeScript',
      stargazers_count: 0,
    },
  ]
}

const feed: FeedItem[] = [
  ...allPosts.map((p) => ({
    kind: 'post' as const,
    title: p.data.title,
    excerpt: p.data.excerpt ?? '',
    href: `/blog/${p.slug}`,
    date: p.data.publishDate ?? null,
    tags: ['post', ...(p.data.tags ?? [])],
    image: p.data.image ?? null,
  })),
  ...projects.map((p) => ({
    kind: 'project' as const,
    title: p.name,
    excerpt: p.description,
    href: p.html_url,
    date: p.pushed_at ? new Date(p.pushed_at) : null,
    tags: ['project', ...(p.language ? [p.language] : [])],
    image: null,
    stars: p.stargazers_count as number,
    language: p.language as string | null,
  })),
]

feed.sort((a, b) => (b.date?.getTime() ?? 0) - (a.date?.getTime() ?? 0))
---

<DefaultLayout
  title="Reads — Frederick Hörner"
  description="Blog posts, thoughts, and projects from Frederick Hörner's development journey."
  keywords="Frederick Hörner, freddo, blog, projects, development, TypeScript, Vue.js, Astro, programming"
>

  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section class="hero" id="reads-hero" aria-label="Reads Archive">
    <canvas id="hero-ascii" aria-hidden="true"></canvas>
    <div class="orb orb-1" aria-hidden="true"></div>
    <div class="orb orb-2" aria-hidden="true"></div>
    <div class="orb orb-3" aria-hidden="true"></div>
    <div class="container hero__container">
      <div class="hero__text reveal">
        <p class="hero__eyebrow">// reads.archive</p>
        <h1 class="hero__name">
          <span class="g-text">Reads</span>
        </h1>
        <p class="hero__subtitle">Posts I wrote. Projects I built.</p>
        <p class="hero__desc">
          A collection of thoughts, tutorials, and open-source work from my journey as a full-stack developer.
        </p>
        <div class="hero-badge reveal">
          <span class="mono">// posts.and.projects</span>
          <span class="hero-badge__sep" aria-hidden="true">—</span>
          <span class="hero-badge__tags">{allPosts.length} posts · {projects.length} projects</span>
        </div>
      </div>
      <div class="hero__image reveal reveal--delay">
        <img
          src="/memoji_pc.png"
          alt="Frederick working at a computer"
          width="300"
          height="300"
          decoding="async"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════ FEED ═══════════════════ -->
  <section class="feed-section">
    <div class="container">
      {feed.length > 0 ? (
        <ReadsFeed items={feed} langColors={langColors} />
      ) : (
        <p class="empty reveal">Nothing here yet.</p>
      )}
    </div>
  </section>

</DefaultLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    // ─── Scroll-reveal ─────────────────────────────────────────────
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('revealed')
            observer.unobserve(e.target)
          }
        })
      },
      { threshold: 0.06 }
    )
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el))

    // ─── ASCII hero wave canvas ───────────────────────────────────
    const asciiCanvas = document.getElementById('hero-ascii') as HTMLCanvasElement | null
    if (asciiCanvas) {
      const ctx = asciiCanvas.getContext('2d', { alpha: true })!
      const CELL = window.innerWidth < 640 ? 36 : 24
      const WATER = [' ', '·', '·', '·', '-', '-', '~', '~', '≈', '≈', '∿', '▲', '▲', '█']
      const FONT = `${Math.round(CELL * 0.5)}px monospace`
      const RIPPLE_LIFE = 2800
      const RIPPLE_SPEED = 0.014
      const RIPPLE_DECAY = 80
      const FPS_CAP = 1000 / 30

      let cols = 0, rows = 0, rafId = 0, lastFrame = 0, heroVisible = true

      type Ripple = { x: number; y: number; born: number; amp: number }
      const ripples: Ripple[] = []

      const resize = () => {
        asciiCanvas.width = asciiCanvas.offsetWidth
        asciiCanvas.height = asciiCanvas.offsetHeight
        cols = Math.ceil(asciiCanvas.width / CELL) + 1
        rows = Math.ceil(asciiCanvas.height / CELL) + 1
      }

      const draw = (ts: number) => {
        rafId = requestAnimationFrame(draw)
        if (document.hidden || !heroVisible || ts - lastFrame < FPS_CAP) return
        lastFrame = ts
        ctx.clearRect(0, 0, asciiCanvas.width, asciiCanvas.height)
        ctx.font = FONT
        ctx.textAlign = 'center'
        ctx.textBaseline = 'middle'
        for (let i = ripples.length - 1; i >= 0; i--) {
          if (ts - ripples[i].born > RIPPLE_LIFE) ripples.splice(i, 1)
        }
        const t = ts * 0.001
        for (let r = 0; r < rows; r++) {
          for (let c = 0; c < cols; c++) {
            const px = c * CELL
            const py = r * CELL
            const base =
              0.6 * Math.sin(c * 0.38 + t * 0.9) +
              0.4 * Math.sin(c * 0.18 - r * 0.12 + t * 0.55) +
              0.2 * Math.sin(r * 0.22 + t * 0.7)
            let rip = 0
            for (const rpl of ripples) {
              const age = (ts - rpl.born) * 0.001
              const dist = Math.hypot(px - rpl.x, py - rpl.y)
              const env = Math.exp(-Math.abs(dist - age * 240) / RIPPLE_DECAY) * Math.exp(-age * 0.9)
              rip += rpl.amp * env * Math.sin(dist * RIPPLE_SPEED - age * 7)
            }
            const norm = Math.max(0, Math.min(1, (base + rip + 1.2) / 3.4))
            const idx = Math.min(WATER.length - 1, Math.floor(norm * WATER.length))
            const ch = WATER[idx]
            if (!ch.trim()) continue
            const glow = Math.min(1, Math.abs(rip) * 0.6)
            const alpha = 0.07 + norm * 0.65 + glow * 0.28
            const gr = Math.round(61 + glow * 115)
            const gg = Math.round(220 - glow * 130)
            const gb = Math.round(190 + glow * 45)
            ctx.fillStyle = `rgba(${gr},${gg},${gb},${alpha})`
            ctx.fillText(ch, px, py)
          }
        }
      }

      const hero = document.getElementById('reads-hero')!
      const heroIO = new IntersectionObserver(([e]) => { heroVisible = e.isIntersecting }, { threshold: 0 })
      heroIO.observe(hero)

      const spawnRipple = (clientX: number, clientY: number, amp: number) => {
        const rect = asciiCanvas.getBoundingClientRect()
        ripples.push({ x: clientX - rect.left, y: clientY - rect.top, born: performance.now(), amp })
        if (ripples.length > 12) ripples.shift()
      }

      let lastMove = 0
      hero.addEventListener('mousemove', (e) => {
        const now = Date.now()
        if (now - lastMove > 120) {
          lastMove = now
          spawnRipple((e as MouseEvent).clientX, (e as MouseEvent).clientY, 1.4)
        }
      })
      hero.addEventListener('click', (e) => {
        const me = e as MouseEvent
        spawnRipple(me.clientX, me.clientY, 4.0)
        setTimeout(() => spawnRipple(me.clientX, me.clientY, 2.5), 120)
      })
      hero.addEventListener('touchstart', (e) => {
        const touch = (e as TouchEvent).touches[0]
        spawnRipple(touch.clientX, touch.clientY, 3.5)
      }, { passive: true })

      const ro = new ResizeObserver(resize)
      ro.observe(asciiCanvas)
      resize()
      rafId = requestAnimationFrame(draw)

      document.addEventListener('astro:before-preparation', () => {
        cancelAnimationFrame(rafId)
        ro.disconnect()
        heroIO.disconnect()
      }, { once: true })
    }
  })
</script>

<style lang="scss">
  .g-text {
    font-weight: 800;
    background: linear-gradient(135deg, var(--primary-100) 0%, var(--secondary-100) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s ease, transform 0.65s ease;

    &.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    &--delay {
      transition-delay: 0.18s;
    }
  }

  #hero-ascii {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(90px);
    z-index: 0;
  }

  .orb-1 {
    width: 650px;
    height: 650px;
    background: radial-gradient(circle, var(--primary-400), transparent 70%);
    opacity: 0.18;
    top: -180px;
    right: -120px;
  }

  .orb-2 {
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, var(--secondary-300), transparent 70%);
    opacity: 0.1;
    bottom: -50px;
    left: -60px;
  }

  .orb-3 {
    width: 240px;
    height: 240px;
    background: radial-gradient(circle, var(--primary-200), transparent 70%);
    opacity: 0.07;
    top: 55%;
    left: 42%;
  }

  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;

    > .container {
      position: relative;
      z-index: 1;
    }
  }

  .hero__container {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 3rem;
    padding-top: 4rem;
    padding-bottom: 4rem;

    @media (max-width: 768px) {
      grid-template-columns: 1fr;
      text-align: center;
    }
  }

  .hero__eyebrow {
    display: block;
    font-family: var(--font-family-mono);
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    color: var(--secondary-200);
    margin-bottom: 0.5rem;
    opacity: 0.7;
  }

  .hero__name {
    font-size: clamp(2.8rem, 6vw, 4.75rem) !important;
    line-height: 1.08 !important;
    margin-bottom: 1.1rem;
  }

  .hero__subtitle {
    font-size: 1.15rem;
    color: var(--neutral-500);
    margin-bottom: 0.9rem;
  }

  .hero__desc {
    font-size: 1rem;
    color: var(--neutral-600);
    line-height: 1.75;
    max-width: 480px;
    margin-bottom: 2rem;

    @media (max-width: 768px) {
      margin-inline: auto;
    }
  }

  .hero__image {
    @media (max-width: 768px) {
      display: flex;
      justify-content: center;
      order: -1;
    }

    img {
      width: 280px;
      height: 280px;
      filter: drop-shadow(0 0 60px rgba(176, 100, 235, 0.22));

      @media (max-width: 768px) {
        width: 180px;
        height: 180px;
      }
    }
  }

  .hero-badge {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 2rem;
    font-size: 0.78rem;
    color: var(--green-200);

    .mono {
      font-family: var(--font-family-mono);
      font-weight: 500;
      letter-spacing: 0.02em;
    }

    &__sep {
      color: rgba(255, 255, 255, 0.12);
    }

    &__tags {
      color: var(--neutral-600);
      font-size: 0.75rem;

      @media (max-width: 480px) {
        display: none;
      }
    }
  }

  .feed-section {
    padding: 4rem 0 6rem;
  }

  .empty {
    padding: 4rem 0;
    text-align: center;
    color: var(--neutral-600);
  }
</style>

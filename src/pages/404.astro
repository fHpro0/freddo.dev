---
import DefaultLayout from '../layouts/DefaultLayout.astro'
---

<DefaultLayout
  title="404 — Page adrift"
  description="This page drifted off into the void. Let's get you back to shore."
>
  <section id="notfound" aria-labelledby="nf-heading">
    <canvas id="notfound-ascii" aria-hidden="true"></canvas>

    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="glass-card nf-card reveal">
      <svg class="nf-avatar" viewBox="0 0 44 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="1" y="1" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.5"/>
        <rect x="25" y="1" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.5"/>
        <line x1="19" y1="10" x2="25" y2="10" stroke="currentColor" stroke-width="1.5"/>
        <g class="nf-eye"><circle cx="10" cy="10" r="2.5" fill="currentColor"/></g>
        <g class="nf-eye"><circle cx="34" cy="10" r="2.5" fill="currentColor"/></g>
      </svg>
      <span class="section-tag" data-nf="tag">page adrift</span>
      <h1 id="nf-heading" class="g-text nf-404">404</h1>
      <p class="nf-copy" data-nf="copy">This page drifted off into the void. Let's get you back to shore.</p>
      <a class="btn btn--primary" data-nf="cta" href="/">Swim home 🏊</a>
    </div>
  </section>

  <!-- One 404 page serves every missing path (incl. /de/*); the host can't pick a
       locale, so swap to German client-side when the path or browser is German. -->
  <script is:inline set:html={`(function(){
    var stored=localStorage.getItem('lang');
    var isDe=location.pathname.indexOf('/de')===0||(stored?stored==='de':(navigator.language||'').slice(0,2)==='de');
    if(!isDe)return;
    document.documentElement.lang='de';
    document.title='404 — Seite abgetrieben';
    var m={tag:'seite abgetrieben',copy:'Diese Seite ist in die Leere abgedriftet. Zurück ans Ufer.',cta:'Heimschwimmen 🏊'};
    for(var k in m){var el=document.querySelector('[data-nf="'+k+'"]');if(el)el.textContent=m[k];}
    var cta=document.querySelector('[data-nf="cta"]');if(cta)cta.setAttribute('href','/de');
  })();`} />
</DefaultLayout>

<script>
  import { initAsciiWater } from '../utils/asciiWater'

  document.addEventListener('astro:page-load', () => {
    // ─── ASCII water canvas (shared hero canvas) ───────────────────
    const asciiCanvas = document.getElementById('notfound-ascii') as HTMLCanvasElement | null
    const nfSection = document.getElementById('notfound')
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    // the page-load listener persists across ViewTransitions, so only run when
    // THIS page's section (#notfound) is actually present
    if (asciiCanvas && nfSection && !reduceMotion) {
      const cleanup = initAsciiWater(asciiCanvas, nfSection)
      document.addEventListener('astro:before-preparation', cleanup, { once: true })
    }

    // ─── Card entrance reveal ───────────────────────────────────────
    const reveals = document.querySelectorAll('#notfound .reveal')
    const revealIO = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed')
          revealIO.unobserve(e.target)
        }
      })
    }, { threshold: 0.1 })
    reveals.forEach((el) => revealIO.observe(el))
  })
</script>

<style lang="scss">
  @use '../assets/scss/base/breakpoint' as *;

  #notfound {
    position: relative;
    min-height: calc(100svh - 6rem);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 2rem 1rem;
  }

  // ─── ASCII canvas ───────────────────────────────────────────────
  #notfound-ascii {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none; // #notfound captures mouse/touch instead
    z-index: 0;
  }

  // ─── Gradient orbs ──────────────────────────────────────────────
  .orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(90px);
    z-index: 0;
  }

  .orb-1 {
    width: 650px;
    height: 650px;
    background: radial-gradient(circle, var(--primary-400), transparent 70%);
    opacity: 0.18;
    top: -180px;
    right: -120px;
  }

  .orb-2 {
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, var(--secondary-300), transparent 70%);
    opacity: 0.1;
    bottom: -50px;
    left: -60px;
  }

  .orb-3 {
    width: 240px;
    height: 240px;
    background: radial-gradient(circle, var(--primary-200), transparent 70%);
    opacity: 0.07;
    top: 55%;
    left: 42%;
  }

  // ─── Message card ───────────────────────────────────────────────
  .nf-card {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
    max-width: 32rem;
    padding: 2.5rem 2rem 2.75rem;
  }

  // ─── Dizzy "lost" avatar (reused nav glasses SVG, funnier) ──────
  .nf-avatar {
    width: 132px;
    height: 60px;
    margin-bottom: 0.75rem;
    color: var(--secondary-200);
    filter: drop-shadow(0 0 30px rgba(61, 220, 190, 0.28));
    transform-origin: center;
    animation: nf-woozy 1.6s ease-in-out infinite;
  }

  .nf-eye {
    transform-box: fill-box;
    transform-origin: center;
    animation: nf-googly 1.2s linear infinite;
  }

  // second eye orbits opposite → cross-eyed dizzy
  .nf-eye:last-of-type {
    animation-direction: reverse;
  }

  // whole avatar tips side to side like it's seasick / adrift
  @keyframes nf-woozy {
    0%, 100% { transform: rotate(-6deg); }
    50%      { transform: rotate(6deg); }
  }

  // pupils orbit their sockets → googly dizzy eyes
  @keyframes nf-googly {
    0%   { transform: translate(2.5px, 0); }
    25%  { transform: translate(0, 2.5px); }
    50%  { transform: translate(-2.5px, 0); }
    75%  { transform: translate(0, -2.5px); }
    100% { transform: translate(2.5px, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .nf-avatar,
    .nf-eye { animation: none; }
  }

  .g-text {
    font-weight: 800;
    background: linear-gradient(135deg, var(--primary-100) 0%, var(--secondary-100) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .nf-404 {
    font-family: var(--font-family-special);
    font-size: clamp(6rem, 20vw, 14rem);
    line-height: 0.9;
    margin: 0.25rem 0 0.5rem;
  }

  .nf-copy {
    color: var(--neutral-300);
    font-size: 1.1rem;
    max-width: 26ch;
    margin-bottom: 1.5rem;
  }

  // ─── Glassmorphism card ─────────────────────────────────────────
  .glass-card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    transition: border-color 0.25s ease, transform 0.25s ease;

    &:hover {
      border-color: rgba(255, 255, 255, 0.14);
    }
  }

  // ─── Scroll-reveal ──────────────────────────────────────────────
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s ease, transform 0.65s ease;

    &.revealed {
      opacity: 1;
      transform: translateY(0);
    }
  }

  // ─── Button ─────────────────────────────────────────────────────
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: filter 0.2s, transform 0.2s, background 0.2s;
    cursor: pointer;
    white-space: nowrap;

    &--primary {
      background: linear-gradient(135deg, var(--primary-200), var(--secondary-300));
      color: #0a0a0e;

      &:hover {
        filter: brightness(1.12);
        transform: translateY(-2px);
        text-decoration: none;
        color: #0a0a0e;
      }

      &:visited { color: #0a0a0e; }
    }
  }
</style>

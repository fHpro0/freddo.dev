---
import Navigation from '../components/Navigation.astro'
import { SkipLinks } from 'accessible-astro-components'
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const base = lang === 'de' ? '/de' : ''
---

<header>
  <SkipLinks />
  <Navigation>
    <li class="menu-item"><a href={`${base}/#about`}><span class="nav-prefix">#</span>{t('nav.about')}</a></li>
    <li class="menu-item"><a href={`${base}/#skills`}><span class="nav-prefix">#</span>{t('nav.skills')}</a></li>
    <li class="menu-item"><a href={`${base}/#featured`}><span class="nav-prefix">#</span>{t('nav.featured')}</a></li>
    <li class="menu-item"><a href={`${base}/reads`}><span class="nav-prefix">/</span>{t('nav.reads')}</a></li>
  </Navigation>
</header>

<style lang="scss" is:global>
  body > header {
    position: sticky;
    top: 0;
    z-index: 100;

    .type-icon a {
      display: block;

      [astro-icon] {
        margin-top: -4px;
        width: 30px;

        path {
          fill: var(--action-color);
        }
      }

      &:hover {
        [astro-icon] path {
          fill: var(--action-color-state);
        }
      }
    }
  }
</style>

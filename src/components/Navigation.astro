---
import ResponsiveToggle from './ResponsiveToggle.astro'
import { DarkMode } from 'accessible-astro-components'
---

<div id="main-navigation" class="is-desktop py-8">
  <div class="container">
    <a href="/" class="flex items-center gap-2 !no-underline">
      <svg id="nav-ascii-avatar" class="nav-avatar" viewBox="0 0 44 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="1" y="1" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.5"/>
        <rect x="25" y="1" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.5"/>
        <line x1="19" y1="10" x2="25" y2="10" stroke="currentColor" stroke-width="1.5"/>
        <g id="nav-eye-left"><circle cx="10" cy="10" r="2.5" fill="currentColor"/></g>
        <g id="nav-eye-right"><circle cx="34" cy="10" r="2.5" fill="currentColor"/></g>
      </svg>
      <span class="nav-logo">freddo<span class="nav-logo__dot">.dev</span></span>
    </a>
    <div class="wrapper">
      <nav class="desktop-menu" aria-label="Main navigation desktop">
        <ul class="menu">
          <slot />
        </ul>
      </nav>
      <DarkMode />
      <ResponsiveToggle />
    </div>
    <nav class="mobile-menu" aria-label="Main navigation mobile">
      <ul class="menu">
        <slot />
      </ul>
    </nav>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    // variables
    const mainNav = document.querySelector('#main-navigation')
    const mainMenu = mainNav.querySelector('ul')
    const dropdownMenus = [...document.querySelectorAll('.has-dropdown button')]

    // functions
    const setActiveMenuItem = () => {
      const mobileDesktopMenus = mainNav.querySelectorAll('nav > ul')
      const currenPathname = window.location.pathname
      const currentHash = window.location.hash

      mobileDesktopMenus.forEach((menu) => {
        const menuItems = [...menu.querySelectorAll('a:not([rel*="external"])')] as HTMLAnchorElement[]

        menuItems.forEach((menuItem) => {
          menuItem.classList.remove('is-active')
          menuItem.removeAttribute('aria-current')

          const href = menuItem.getAttribute('href') || ''
          const isHashLink = href.includes('#')

          if (isHashLink) {
            // hash links: only activate on homepage via scroll-spy or matching hash
            if (currenPathname === '/' && currentHash && href === `/${currentHash}`) {
              menuItem.classList.add('is-active')
              menuItem.setAttribute('aria-current', 'page')
            }
          } else {
            // path links: exact or prefix match
            const itemPath = menuItem.pathname
            if (itemPath !== '/' && currenPathname.startsWith(itemPath)) {
              menuItem.classList.add('is-active')
              menuItem.setAttribute('aria-current', 'page')
            }
          }
        })
      })
    }

    const checkMenuSize = () => {
      const mainNavWidth = mainNav.getBoundingClientRect().width
      const desktopMenuWidth = document.querySelector('.desktop-menu').getBoundingClientRect().width
      const logoWidthBuffer = 300
      const totalMenuWidth = Math.round(desktopMenuWidth) + logoWidthBuffer

      if (totalMenuWidth >= mainNavWidth) {
        mainNav.classList.remove('is-desktop')
        mainNav.classList.add('is-mobile')
      } else if (totalMenuWidth <= mainNavWidth) {
        mainNav.classList.add('is-desktop')
        mainNav.classList.remove('is-mobile')
      }
    }

    const isOutOfViewport = (element) => {
      const elementBounds = element.getBoundingClientRect()
      return elementBounds.right > (window.innerWidth || document.documentElement.clientWidth)
    }

    const openDropdownMenu = (dropdownMenu) => {
      const dropdownList = dropdownMenu.parentNode.querySelector('ul')

      dropdownMenu.classList.add('show')
      dropdownMenu.setAttribute('aria-expanded', 'true')

      if (isOutOfViewport(dropdownList)) {
        dropdownList.style.left = 'auto'
      }
    }

    const closeDropdownMenu = (dropdownMenu) => {
      dropdownMenu.classList.remove('show')
      dropdownMenu.setAttribute('aria-expanded', 'false')
    }

    const closeAllDropdownMenus = () => {
      for (let i = 0; i < dropdownMenus.length; i++) {
        closeDropdownMenu(dropdownMenus[i])
      }
    }

    const toggleDropdownMenu = (event) => {
      if (event.target.getAttribute('aria-expanded') === 'false') {
        closeAllDropdownMenus()
        openDropdownMenu(event.target)
      } else {
        closeDropdownMenu(event.target)
      }
    }

    // ─── SVG nerd avatar — smooth mouse tracking + reactions ────────────
    const avatar = document.getElementById('nav-ascii-avatar')
    if (avatar) {
      const eyeL = document.getElementById('nav-eye-left')!
      const eyeR = document.getElementById('nav-eye-right')!

      // eye centers in SVG coords (viewBox 0 0 44 20)
      const LX = 10, RX = 34, EY = 10
      const maxShift = 3.5
      const r = 2.5

      type EyeSet = { l: string; r: string }
      const S: Record<string, EyeSet> = {
        blink: {
          l: `<line x1="4" y1="10" x2="16" y2="10" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>`,
          r: `<line x1="28" y1="10" x2="40" y2="10" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>`,
        },
        excited: {
          l: `<circle cx="10" cy="10" r="4.5" fill="currentColor"/>`,
          r: `<circle cx="34" cy="10" r="4.5" fill="currentColor"/>`,
        },
        happy: {
          l: `<path d="M4 12 Q10 5 16 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>`,
          r: `<path d="M28 12 Q34 5 40 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>`,
        },
        love: {
          l: `<path d="M10 13C10 13 6 10.5 6 8.5C6 7 7.2 6 10 7.8C12.8 6 14 7 14 8.5C14 10.5 10 13 10 13Z" fill="currentColor"/>`,
          r: `<path d="M34 13C34 13 30 10.5 30 8.5C30 7 31.2 6 34 7.8C36.8 6 38 7 38 8.5C38 10.5 34 13 34 13Z" fill="currentColor"/>`,
        },
        // blinded by the light — wide-eyed shock
        shock: {
          l: `<circle cx="10" cy="10" r="5.5" fill="none" stroke="currentColor" stroke-width="1.8"/><circle cx="10" cy="10" r="2" fill="currentColor"/>`,
          r: `<circle cx="34" cy="10" r="5.5" fill="none" stroke="currentColor" stroke-width="1.8"/><circle cx="34" cy="10" r="2" fill="currentColor"/>`,
        },
        // slam on fully black sunglasses against the glare
        shades: {
          l: `<rect x="2" y="2" width="16" height="16" rx="2.5" fill="#000"/>`,
          r: `<rect x="26" y="2" width="16" height="16" rx="2.5" fill="#000"/>`,
        },
        // seeing stars — dazed * eyes
        stars: {
          l: `<path d="M10 5 L11.1 9 L15 10 L11.1 11 L10 15 L8.9 11 L5 10 L8.9 9 Z" fill="currentColor"/>`,
          r: `<path d="M34 5 L35.1 9 L39 10 L35.1 11 L34 15 L32.9 11 L29 10 L32.9 9 Z" fill="currentColor"/>`,
        },
        // dizzy — big spiral swirl eyes
        woozy: {
          l: `<path d="M5.5 10 a4.5 4.5 0 1 1 9 0 a3 3 0 1 1 -6 0 a1.5 1.5 0 1 1 3 0" stroke="currentColor" stroke-width="1.6" fill="none"/>`,
          r: `<path d="M29.5 10 a4.5 4.5 0 1 1 9 0 a3 3 0 1 1 -6 0 a1.5 1.5 0 1 1 3 0" stroke="currentColor" stroke-width="1.6" fill="none"/>`,
        },
        // droopy downturned eyes
        sad: {
          l: `<path d="M4 8 Q10 14 16 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>`,
          r: `<path d="M28 8 Q34 14 40 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>`,
        },
      }

      let reactUntil = 0
      let currentDx = 0
      let currentDy = 0

      const setTrack = (dx: number, dy: number) => {
        currentDx = dx; currentDy = dy
        const lx = (LX + dx).toFixed(2); const ly = (EY + dy).toFixed(2)
        const rx = (RX + dx).toFixed(2); const ry = (EY + dy).toFixed(2)
        eyeL.innerHTML = `<circle cx="${lx}" cy="${ly}" r="${r}" fill="currentColor"/>`
        eyeR.innerHTML = `<circle cx="${rx}" cy="${ry}" r="${r}" fill="currentColor"/>`
      }

      const setState = (state: string) => {
        const s = S[state]; if (!s) return
        eyeL.innerHTML = s.l; eyeR.innerHTML = s.r
      }

      const restore = () => setTrack(currentDx, currentDy)
      setTrack(0, 0)

      const reactTimers: ReturnType<typeof setTimeout>[] = []
      const clearReact = () => { reactTimers.forEach(clearTimeout); reactTimers.length = 0 }

      // mouse yanked too fast → dizzy spiral eyes
      const wooze = () => {
        clearReact()
        const spinMs = 1300, starMs = 650, sadMs = 750
        reactUntil = Date.now() + spinMs + starMs + sadMs
        setState('woozy')
        avatar.classList.add('is-woozy')
        // spin ends → stop wobble/spin, see stars
        reactTimers.push(setTimeout(() => {
          avatar.classList.remove('is-woozy')
          setState('stars')
        }, spinMs))
        // then a sad droopy face
        reactTimers.push(setTimeout(() => setState('sad'), spinMs + starMs))
        // finally recover to normal
        reactTimers.push(setTimeout(() => {
          reactUntil = 0
          restore()
        }, spinMs + starMs + sadMs))
      }

      let prevX = 0, prevY = 0, prevT = 0
      let lastVX = 0, lastVY = 0, shakeCount = 0, lastShakeT = 0
      const trackMouse = (e: MouseEvent) => {
        const now = e.timeStamp || Date.now()
        const dt = now - prevT
        const vx = e.clientX - prevX
        const vy = e.clientY - prevY
        const moved = Math.hypot(vx, vy)
        const speed = dt > 0 ? moved / dt : 0 // px per ms
        prevX = e.clientX; prevY = e.clientY; prevT = now

        // intentional shaking = fast moves that keep reversing direction
        if (dt > 0 && dt < 120 && speed > 1.8 && moved > 25) {
          if (now - lastShakeT > 400) shakeCount = 0 // window lapsed → reset
          const reversed = vx * lastVX + vy * lastVY < 0
          if (reversed) {
            shakeCount++
            lastShakeT = now
            if (shakeCount >= 4 && Date.now() >= reactUntil) { shakeCount = 0; wooze(); return }
          }
          lastVX = vx; lastVY = vy
        }

        if (Date.now() < reactUntil) return

        const rect = avatar.getBoundingClientRect()
        const cx = rect.left + rect.width / 2
        const cy = rect.top + rect.height / 2
        const dx = e.clientX - cx
        const dy = e.clientY - cy
        const dist = Math.hypot(dx, dy)

        if (dist < 60) { setTrack(0, 0); return }

        const scale = Math.min(dist / 150, 1) * maxShift
        setTrack((dx / dist) * scale, (dy / dist) * scale)
      }

      window.addEventListener('mousemove', trackMouse)

      const onClick = (e: MouseEvent) => {
        // darkmode toggle owns its own reaction (heart / flashbang)
        if ((e.target as Element)?.closest?.('.darkmode-toggle')) return
        reactUntil = Date.now() + 700
        setState('excited')
        setTimeout(() => {
          reactUntil = Date.now() + 400
          setState('happy')
          setTimeout(() => { restore() }, 400)
        }, 700)
      }
      window.addEventListener('click', onClick)

      avatar.addEventListener('mouseenter', () => {
        reactUntil = Date.now() + 99999
        setState('love')
      })
      avatar.addEventListener('mouseleave', () => {
        reactUntil = 0
        restore()
      })

      // hovering the text logo also triggers love eyes + glitch animation
      const navLogo = document.querySelector('.nav-logo') as HTMLElement | null
      if (navLogo) {
        navLogo.addEventListener('mouseenter', () => {
          reactUntil = Date.now() + 99999
          setState('love')
        })
        navLogo.addEventListener('mouseleave', () => {
          reactUntil = 0
          restore()
        })
      }

      // ─── light mode = flashbang. avatar gets blinded. ──────────────
      let flashEl = document.querySelector('.theme-flash') as HTMLDivElement | null
      if (!flashEl) {
        flashEl = document.createElement('div')
        flashEl.className = 'theme-flash'
        document.body.appendChild(flashEl)
      }

      // dark → light: flashbang, slam on black shades, then see stars
      const blindReaction = () => {
        clearReact()
        // screen white-flash (restart animation via reflow)
        flashEl!.classList.remove('is-flashing')
        void flashEl!.offsetWidth
        flashEl!.classList.add('is-flashing')

        reactUntil = Date.now() + 2200
        setState('shock')
        avatar.classList.add('is-blinded')
        reactTimers.push(setTimeout(() => setState('shades'), 160)) // black glasses first
        reactTimers.push(setTimeout(() => setState('stars'), 900))  // then * eyes
        reactTimers.push(setTimeout(() => {
          avatar.classList.remove('is-blinded')
          reactUntil = 0
          restore()
        }, 1900))
      }

      // light → dark: relief — heart eyes
      const heartReaction = () => {
        clearReact()
        reactUntil = Date.now() + 1300
        setState('love')
        reactTimers.push(setTimeout(() => { reactUntil = 0; restore() }, 1300))
      }

      let wasDark = document.body.classList.contains('darkmode')
      const themeObserver = new MutationObserver(() => {
        const isDark = document.body.classList.contains('darkmode')
        if (wasDark && !isDark) blindReaction()       // dark → light
        else if (!wasDark && isDark) heartReaction()  // light → dark
        wasDark = isDark
      })
      themeObserver.observe(document.body, { attributes: true, attributeFilter: ['class'] })

      const schedBlink = () => {
        const delay = 3000 + Math.random() * 2000
        return setTimeout(() => {
          if (Date.now() >= reactUntil) {
            setState('blink')
            setTimeout(() => {
              if (Date.now() >= reactUntil) restore()
              blinkTimer = schedBlink()
            }, 130)
          } else {
            blinkTimer = schedBlink()
          }
        }, delay)
      }
      let blinkTimer = schedBlink()

      document.addEventListener('astro:before-preparation', () => {
        clearTimeout(blinkTimer)
        window.removeEventListener('mousemove', trackMouse)
        window.removeEventListener('click', onClick)
        themeObserver.disconnect()
        clearReact()
        flashEl?.remove()
      }, { once: true })
    }

    // execution
    mainMenu &&
      mainMenu.addEventListener('keydown', (event) => {
        const element = event.target as Element
        const currentMenuItem = element.closest('li')
        const menuItems = [...mainMenu.querySelectorAll('.menu-item')]
        const currentDropdownMenu = element.closest('.has-dropdown button')
        const currentDropdownMenuItem = element.closest('.has-dropdown li')
        const currentIndex = menuItems.findIndex((item) => item === currentMenuItem)

        const key = event.key
        let targetItem

        if (key === 'ArrowRight') {
          if (menuItems.indexOf(currentMenuItem) === menuItems.length - 1) {
            targetItem = menuItems[0]
          } else {
            targetItem = menuItems[currentIndex + 1]
          }
        }

        if (key === 'ArrowLeft') {
          if (menuItems.indexOf(currentMenuItem) === 0) {
            targetItem = menuItems[menuItems.length - 1]
          } else {
            targetItem = menuItems[currentIndex - 1]
          }
        }

        if (key === 'Escape') {
          targetItem = menuItems[0]
        }

        if (currentDropdownMenu) {
          const firstDropdownItem = currentDropdownMenu.nextElementSibling.querySelector('li')

          if (key === 'ArrowDown') {
            event.preventDefault()
            openDropdownMenu(currentDropdownMenu)
            targetItem = firstDropdownItem
          }

          if (key === 'Escape') {
            closeDropdownMenu(currentDropdownMenu)
          }
        }

        if (currentDropdownMenuItem) {
          const currentDropdownList = currentDropdownMenuItem.parentNode
          const dropdownMenuItems = [...currentDropdownList.querySelectorAll('li')]
          const currentIndex = dropdownMenuItems.findIndex((item) => item === currentDropdownMenuItem)

          if (key === 'ArrowDown') {
            event.preventDefault()

            if (dropdownMenuItems.indexOf(currentDropdownMenuItem as HTMLLIElement) === dropdownMenuItems.length - 1) {
              targetItem = dropdownMenuItems[0]
            } else {
              targetItem = dropdownMenuItems[currentIndex + 1]
            }
          }

          if (key === 'ArrowUp') {
            event.preventDefault()

            if (dropdownMenuItems.indexOf(currentDropdownMenuItem as HTMLLIElement) === 0) {
              targetItem = dropdownMenuItems[dropdownMenuItems.length - 1]
            } else {
              targetItem = dropdownMenuItems[currentIndex - 1]
            }
          }

          if (key === 'Escape') {
            const currentDropdownMenu = (currentDropdownList as Element).previousElementSibling
            targetItem = currentDropdownMenu.parentNode
            closeAllDropdownMenus()
          }
        }

        if (targetItem) {
          targetItem.querySelector('a, button, input').focus()
        }
      })

    dropdownMenus &&
      dropdownMenus.forEach((dropdownMenu) => {
        dropdownMenu.addEventListener('click', toggleDropdownMenu)
      })

    setActiveMenuItem()
    checkMenuSize()

    // scroll-spy for homepage anchor sections
    if (window.location.pathname === '/') {
      const sections = ['about', 'skills', 'featured']
      const sectionEls = sections.map((id) => document.getElementById(id)).filter(Boolean) as HTMLElement[]

      const spyObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return
            const id = entry.target.id
            mainNav.querySelectorAll('nav > ul a').forEach((link) => {
              const a = link as HTMLAnchorElement
              const isMatch = a.getAttribute('href') === `/#${id}`
              a.classList.toggle('is-active', isMatch)
              if (isMatch) {
                a.setAttribute('aria-current', 'page')
              } else {
                a.removeAttribute('aria-current')
              }
            })
          })
        },
        { threshold: 0.35 }
      )

      sectionEls.forEach((el) => spyObserver.observe(el))
    }

    window.addEventListener('resize', checkMenuSize)
    window.addEventListener('click', (event) => {
      const element = event.target as Element
      if (!element.hasAttribute('aria-haspopup') && !element.classList.contains('submenu-item')) {
        closeAllDropdownMenus()
      }
    })
  })
</script>

<style lang="scss" is:global>
  @use '../assets/scss/base/breakpoint' as *;
  @use '../assets/scss/base/outline' as *;

  #main-navigation {
    z-index: 100;
    background: rgba(4, 8, 6, 0.94);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(34, 197, 94, 0.08);

    > .container {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
    }

    &.is-desktop {
      .desktop-menu {
        visibility: visible;
        position: static;
      }

      .mobile-menu {
        display: none;
      }

      .darkmode-toggle {
        margin-top: -6px;
      }
    }

    &.is-mobile {
      flex-direction: column;

      .mobile-menu {
        display: none;

        &.show {
          display: block;
        }
      }

      .desktop-menu {
        visibility: hidden;
        z-index: -99;
        position: absolute;
        left: 0;
      }

      .responsive-toggle {
        display: block;
      }
    }

    .wrapper {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    nav {
      > ul {
        display: flex;
        gap: 1.5rem;
        list-style-type: none;

        a,
        button {
          font-family: var(--font-family-mono);
          text-decoration: none;
          font-size: 0.875rem;
          line-height: 1.6875rem;
          letter-spacing: 0.02em;
        }

        .nav-prefix {
          opacity: 0.4;
          font-size: 0.75rem;
          font-weight: 400 !important;
          margin-right: 1px;
        }

        a:hover,
        a:focus,
        .is-active,
        .has-dropdown > button:hover,
        .has-dropdown > button:focus {
          text-decoration: underline;
          text-decoration-thickness: 1px;
          text-decoration-style: wavy;
          text-underline-offset: 7px;
        }

        .is-active {
          font-weight: bold;
        }
      }
    }

    .mobile-menu {
      flex-basis: 100%;
      padding: 2rem 0;

      > ul {
        flex-direction: column;

        ul {
          position: relative;
          margin-top: 1rem;
        }
      }

      a,
      button {
        display: block;
        width: 100%;
        padding: 0.5rem 0;
      }
    }

    .has-dropdown {
      position: relative;

      > button {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0;
        margin-top: -1px;
        border: none;
        color: var(--action-color);

        &:hover {
          color: var(--action-color-state);

          &::after {
            border-color: var(--action-color-state);
          }
        }

        &::after {
          content: '';
          width: 0.85rem;
          height: 0.75em;
          margin-top: -0.25rem;
          border-style: solid;
          border-width: 0.2em 0.2em 0 0;
          border-color: var(--action-color);
          transform: rotate(135deg);
        }

        &.show {
          &::after {
            margin-top: 0.25rem;
            transform: rotate(-45deg);
          }

          ~ ul {
            display: flex;
            flex-direction: column;
            gap: 1rem;
          }
        }
      }

      ul {
        display: none;
        position: absolute;
        z-index: 100;
        min-width: 260px;
        top: 125%;
        right: 0;
        bottom: auto;
        left: 0;
        padding: 1rem;
        background-color: var(--neutral-background);
        border: 2px solid black;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
      }
    }
  }

  .nav-avatar {
    width: 44px;
    height: 20px;
    flex-shrink: 0;
    color: var(--secondary-200);
    opacity: 0.7;
    display: inline-block;
    vertical-align: middle;
    transition: opacity 0.2s, color 0.2s;
    user-select: none;
    cursor: default;

    &:hover {
      opacity: 1;
      color: var(--primary-100);
    }
  }

  @keyframes nav-glitch {
    0%   { transform: none; filter: none; }
    10%  { transform: skewX(-10deg) translateX(-3px); filter: drop-shadow(2px 0 var(--primary-100)) drop-shadow(-2px 0 var(--secondary-100)); }
    20%  { transform: skewX(7deg) translateX(2px);  filter: none; }
    30%  { transform: skewX(-5deg) translateX(-1px); filter: drop-shadow(-3px 0 var(--primary-200)); }
    40%  { transform: skewX(9deg) translateX(2px);  filter: none; }
    50%  { transform: translateX(3px);             filter: drop-shadow(2px 0 var(--secondary-100)); }
    60%  { transform: none; filter: none; }
    70%  { transform: skewX(-7deg) translateX(1px);  filter: drop-shadow(-1px 0 var(--primary-100)) drop-shadow(1px 0 var(--secondary-200)); }
    80%  { transform: none; filter: none; }
    100% { transform: none; filter: none; }
  }

  // full-screen flashbang when someone dares switch to light mode
  .theme-flash {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #fff;
    opacity: 0;
    pointer-events: none;

    &.is-flashing {
      animation: theme-flashbang 0.6s ease-out;
    }
  }

  @keyframes theme-flashbang {
    0%   { opacity: 0; }
    8%   { opacity: 0.95; }
    100% { opacity: 0; }
  }

  @keyframes nav-blinded-shake {
    0%, 100% { transform: translateX(0) rotate(0); }
    20%      { transform: translateX(-2px) rotate(-5deg); }
    40%      { transform: translateX(2px) rotate(4deg); }
    60%      { transform: translateX(-2px) rotate(-3deg); }
    80%      { transform: translateX(1px) rotate(2deg); }
  }

  .nav-avatar.is-blinded {
    animation: nav-blinded-shake 0.4s ease-in-out 2;
  }

  @keyframes nav-eye-spin {
    to { transform: rotate(360deg); }
  }

  @keyframes nav-woozy-wobble {
    0%, 100% { transform: rotate(0); }

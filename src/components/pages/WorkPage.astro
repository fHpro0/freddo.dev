---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import { fetchRepos, LANGUAGE_COLORS as langColors, FALLBACK_DESCRIPTION } from '../../utils/github'
import { getLangFromUrl, useTranslations } from '../../i18n/utils'

const t = useTranslations(getLangFromUrl(Astro.url))
const projects = await fetchRepos()
---

<DefaultLayout
  title={t('work.meta.title')}
  description={t('work.meta.description')}
  keywords="Frederick Hörner, freddo, projects, GitHub, portfolio, TypeScript, Vue.js, Python, open source"
>

  <section class="section" id="work" aria-labelledby="work-heading">
    <div class="container">
      <p class="section-tag text-center reveal">full.catalog</p>
      <h1 id="work-heading" class="section-title text-center reveal">
        <span class="g-text">{t('work.title')}</span>
      </h1>
      <p class="section-sub text-center reveal">
        {t('work.subBefore')}<a href="https://github.com/fHpro0" target="_blank" rel="noopener noreferrer">GitHub</a>{t('work.subAfter')}
      </p>

      {projects.length > 0 ? (
        <div class="projects-grid">
          {projects.map((project) => (
            <a
              href={project.html_url}
              target="_blank"
              rel="noopener noreferrer"
              class="glass-card project-card reveal"
              aria-label={`${project.name}: ${project.description ?? FALLBACK_DESCRIPTION}`}
            >
              <div class="project-card__header">
                <h2 class="project-card__name">{project.name}</h2>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="project-card__arrow" aria-hidden="true">
                  <path d="M7 17L17 7M7 7h10v10"/>
                </svg>
              </div>
              <p class="project-card__desc">{project.description ?? FALLBACK_DESCRIPTION}</p>
              <div class="project-card__meta">
                {project.language && (
                  <span class="project-card__lang" style={`--lc: ${langColors[project.language] ?? '#888'}`}>
                    {project.language}
                  </span>
                )}
                {project.stargazers_count > 0 && (
                  <span class="project-card__stars">⭐ {project.stargazers_count}</span>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="fallback-projects reveal">
          <p class="fallback-projects__text">{t('work.fallback')}</p>
          <a href="https://github.com/fHpro0" target="_blank" rel="noopener noreferrer" class="btn btn--ghost">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            fHpro0 on GitHub
          </a>
        </div>
      )}
    </div>
  </section>

</DefaultLayout>

<style lang="scss">
  .section {
    padding: 5rem 0;
  }

  .text-center {
    text-align: center;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .section-sub {
    font-size: 1.05rem;
    color: var(--neutral-600);
    margin-bottom: 3rem;

    a {
      color: var(--secondary-200);
      text-decoration: underline;
      text-decoration-color: transparent;
      transition: text-decoration-color 0.2s;

      &:hover {
        text-decoration-color: var(--secondary-200);
      }
    }
  }

  .g-text {
    font-weight: 800;
    background: linear-gradient(135deg, var(--primary-100) 0%, var(--secondary-100) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .glass-card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 2rem;
    transition: border-color 0.25s ease, transform 0.25s ease;

    &:hover {
      border-color: rgba(255, 255, 255, 0.14);
    }
  }

  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s ease, transform 0.65s ease;

    &.revealed {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: filter 0.2s, transform 0.2s, background 0.2s;
    cursor: pointer;
    white-space: nowrap;

    &--ghost {
      background: rgba(255, 255, 255, 0.06);
      color: var(--neutral-300);
      border: 1px solid rgba(255, 255, 255, 0.1);

      &:hover {
        background: rgba(255, 255, 255, 0.11);
        transform: translateY(-2px);
        text-decoration: none;
        color: var(--neutral-100);
      }

      &:visited { color: var(--neutral-300); }
    }
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
    gap: 1.25rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;

    &:hover {
      transform: translateY(-5px);
      border-color: rgba(255, 255, 255, 0.18);
    }

    &__header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 0.6rem;
    }

    &__arrow {
      opacity: 0.35;
      flex-shrink: 0;
      margin-top: 3px;
      transition: opacity 0.2s, transform 0.2s;
    }

    &:hover &__arrow {
      opacity: 0.8;
      transform: translate(2px, -2px);
    }

    &__name {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--neutral-100);
      margin: 0;
      line-height: 1.4;
    }

    &__desc {
      flex: 1;
      font-size: 0.85rem;
      color: var(--neutral-600);
      line-height: 1.6;
      margin-bottom: 1rem;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    &__meta {
      display: flex;
      gap: 0.875rem;
      align-items: center;
      margin-top: auto;
    }

    &__lang {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.78rem;
      color: var(--neutral-500);

      &::before {
        content: '';
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: var(--lc, #888);
        flex-shrink: 0;
      }
    }

    &__stars {
      font-size: 0.78rem;
      color: var(--neutral-600);
    }
  }

  .fallback-projects {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 3rem 0;

    &__text {
      color: var(--neutral-600);
      font-size: 1.05rem;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('revealed')
            observer.unobserve(e.target)
          }
        })
      },
      { threshold: 0.08 }
    )
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el))
  })
</script>

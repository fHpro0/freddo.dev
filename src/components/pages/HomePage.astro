<script>
  import { initAsciiWater } from '../../utils/asciiWater'

  document.addEventListener('astro:page-load', () => {
    // ─── Scroll-reveal ────────────────────────────────────────────
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('revealed')
            observer.unobserve(e.target)
          }
        })
      },
      { threshold: 0.08 }
    )
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el))

    // ─── ASCII hero water/wave canvas (shared) ───────────────────
    const asciiCanvas = document.getElementById('hero-ascii') as HTMLCanvasElement | null
    const heroSection = document.getElementById('home')
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (asciiCanvas && heroSection && !reduceMotion) {
      const cleanup = initAsciiWater(asciiCanvas, heroSection)
      document.addEventListener('astro:before-preparation', cleanup, { once: true })
    }

    // ─── Skill tree reveal ───────────────────────────────────────
    const skillTree = document.getElementById('skill-tree')
    if (skillTree) {
      const treeObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('tree--revealed')
              treeObserver.unobserve(e.target)
            }
          })
        },
        { threshold: 0.05 }
      )
      treeObserver.observe(skillTree)
    }
  })
</script>


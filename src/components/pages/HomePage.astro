---
import { Image } from 'astro:assets'
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import memojiHello from '../../assets/images/memoji_hello.png'
import memojiPc from '../../assets/images/memoji_pc.png'
import { getLangFromUrl, useTranslations } from '../../i18n/utils'

const t = useTranslations(getLangFromUrl(Astro.url))

const featuredProject = {
  name: 'freddo.dev',
  url: 'https://github.com/fHpro0/freddo.dev',
  image: '',
  tags: ['Astro', 'TypeScript', 'SCSS'],
}

// About paragraph carries inline links; render placeholders as anchors (trusted content)
const aboutP1 = t('home.about.p1')
  .replace('{scherdel}', '<a href="https://www.scherdel.com" target="_blank" rel="noopener noreferrer">Scherdel</a>')
  .replace('{tmt}', '<a href="https://www.tmt.de" target="_blank" rel="noopener noreferrer">TMT</a>')
---

<DefaultLayout
  title={t('home.meta.title')}
  description={t('home.meta.description')}
  keywords="Frederick Hörner, freddo, fHpro0, Full-Stack Developer, TypeScript, Vue.js, Python, PHP, Astro, Flutter, React Native, Capacitor, AI, LLM, TMT, portfolio, developer"
>

  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section class="hero" id="home" aria-label="Introduction">
    <canvas id="hero-ascii" aria-hidden="true"></canvas>
    <div class="orb orb-1" aria-hidden="true"></div>
    <div class="orb orb-2" aria-hidden="true"></div>
    <div class="orb orb-3" aria-hidden="true"></div>
    <div class="container hero__container">
      <div class="hero__text reveal">
        <p class="hero__eyebrow">{t('home.hero.eyebrow')}</p>
        <h1 class="hero__name">
          <span class="g-text">Frederick Hörner</span>
        </h1>
        <p class="hero__subtitle">
          {t('home.hero.role')}&ensp;<span class="hero__at">@</span>&ensp;<a
            href="https://www.tmt.de"
            target="_blank"
            rel="noopener noreferrer"
            class="hero__company">TMT</a>
        </p>
        <p class="hero__desc">
          {t('home.hero.desc')}
        </p>
        <div class="hero-badge reveal">
          <span class="mono">// fullstack.dev</span>
          <span class="hero-badge__sep" aria-hidden="true">—</span>
          <span class="hero-badge__tags">TypeScript · Vue · Python · Astro</span>
        </div>
        <div class="hero__actions">
          <a href="https://github.com/fHpro0" target="_blank" rel="noopener noreferrer" class="btn btn--ghost">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/frederick-hörner-8942a82a8/" target="_blank" rel="noopener noreferrer" class="btn btn--primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
          <a href="https://www.instagram.com/fH_pro0" target="_blank" rel="noopener noreferrer" class="btn btn--ghost">
            Instagram
          </a>
        </div>
      </div>
      <div class="hero__image reveal reveal--delay">
        <Image
          src={memojiHello}
          alt="Frederick's memoji waving hello"
          width={300}
          height={326}
          densities={[1, 2]}
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════ STATS ═══════════════════ -->
  <section class="stats-strip" aria-label="Key statistics">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item reveal">
          <span class="stat-num mono">5+</span>
          <span class="stat-lbl">{t('home.stats.experience')}</span>
        </div>
        <div class="stat-item reveal">
          <span class="stat-num mono">15+</span>
          <span class="stat-lbl">{t('home.stats.technologies')}</span>
        </div>
        <div class="stat-item reveal">
          <span class="stat-num mono">50+</span>
          <span class="stat-lbl">{t('home.stats.projects')}</span>
        </div>
        <div class="stat-item reveal">
          <span class="stat-num stat-num--inf mono">∞</span>
          <span class="stat-lbl">{t('home.stats.curiosity')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ ABOUT ═══════════════════ -->
  <section class="section" id="about" aria-labelledby="about-heading">
    <div class="container">
      <div class="about-grid">
        <div class="glass-card about-card reveal">
          <p class="section-tag">about.me</p>
          <h2 id="about-heading" class="section-title"><span class="g-text">{t('home.about.title')}</span></h2>
          <p class="about-text" set:html={aboutP1} />
          <p class="about-text">
            {t('home.about.p2')}
          </p>
          <div class="stats">
            <div class="stat">
              <span class="stat__number g-text">5+</span>
              <span class="stat__label">{t('home.stats.experience')}</span>
            </div>
            <div class="stat">
              <span class="stat__number g-text">15+</span>
              <span class="stat__label">{t('home.stats.technologies')}</span>
            </div>
            <div class="stat">
              <span class="stat__number g-text">∞</span>
              <span class="stat__label">{t('home.stats.curiosity')}</span>
            </div>
          </div>
        </div>
        <div class="about-memoji reveal reveal--delay">
          <Image
            src={memojiPc}
            alt="Frederick working at a computer"
            width={240}
            height={287}
            densities={[1, 2]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ SKILLS ═══════════════════ -->
  <section class="section" id="skills" aria-labelledby="skills-heading">
    <div class="container">
      <p class="section-tag text-center reveal">tools.and.stack</p>
      <h2 id="skills-heading" class="section-title text-center reveal">
        <span class="g-text">{t('home.skills.title')}</span>
      </h2>
      <p class="section-sub text-center reveal">{t('home.skills.sub')}</p>

      <div class="skill-tree" id="skill-tree">
        <div class="tree-trunk"></div>
        <div class="branches-row">

        <div class="branch branch--lang" style="--branch-delay: 0.3s">
          <div class="branch-head">
            <span class="branch-node" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </span>
            <span class="branch-line"></span>
            <span class="branch-label">{t('home.skills.languages')}</span>
          </div>
          <div class="branch-nodes">
            <div class="tree-node" style="--delay: 0.6s"><div class="node-circle"><i class="devicon-typescript-plain colored"></i></div><span>TypeScript</span></div>
            <div class="tree-node" style="--delay: 0.67s"><div class="node-circle"><i class="devicon-javascript-plain colored"></i></div><span>JavaScript</span></div>
            <div class="tree-node" style="--delay: 0.74s"><div class="node-circle"><i class="devicon-python-plain colored"></i></div><span>Python</span></div>
            <div class="tree-node" style="--delay: 0.81s"><div class="node-circle"><i class="devicon-php-plain colored"></i></div><span>PHP</span></div>
            <div class="tree-node" style="--delay: 0.88s"><div class="node-circle"><i class="devicon-html5-plain colored"></i></div><span>HTML5</span></div>
            <div class="tree-node" style="--delay: 0.95s"><div class="node-circle"><i class="devicon-css3-plain colored"></i></div><span>CSS3</span></div>
            <div class="tree-node" style="--delay: 1.02s"><div class="node-circle"><i class="devicon-sass-plain colored"></i></div><span>Sass</span></div>
            <div class="tree-node" style="--delay: 1.09s"><div class="node-circle"><i class="devicon-go-plain colored"></i></div><span>Go</span></div>
          </div>
        </div>

        <div class="branch branch--fw" style="--branch-delay: 0.44s">
          <div class="branch-head">
            <span class="branch-node" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            </span>
            <span class="branch-line"></span>
            <span class="branch-label">{t('home.skills.frameworks')}</span>
          </div>
          <div class="branch-nodes">
            <div class="tree-node" style="--delay: 0.74s"><div class="node-circle"><i class="devicon-astro-plain colored"></i></div><span>Astro</span></div>
            <div class="tree-node" style="--delay: 0.81s"><div class="node-circle"><i class="devicon-vuejs-plain colored"></i></div><span>Vue.js</span></div>
            <div class="tree-node" style="--delay: 0.88s"><div class="node-circle"><i class="devicon-tailwindcss-plain colored"></i></div><span>Tailwind</span></div>
            <div class="tree-node" style="--delay: 0.95s"><div class="node-circle"><svg class="node-svg" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12.445.002a45.529 45.529 0 0 0-5.252 8.146 8.595 8.595 0 0 1-.555-.53 27.796 27.796 0 0 0-1.205-1.542 8.762 8.762 0 0 0-1.251 2.12 20.743 20.743 0 0 0-1.448 5.88 8.867 8.867 0 0 0 .338 3.468c1.312 3.48 3.794 5.593 7.445 6.337 3.055.438 5.755-.333 8.097-2.312 2.677-2.59 3.359-5.634 2.047-9.132a33.287 33.287 0 0 0-2.988-5.59A91.34 91.34 0 0 0 12.615.053a.216.216 0 0 0-.17-.051Zm-.336 3.906a50.93 50.93 0 0 1 4.794 6.552c.448.767.817 1.57 1.108 2.41.606 2.386-.044 4.354-1.951 5.904-1.845 1.298-3.87 1.683-6.072 1.156-2.376-.737-3.75-2.335-4.121-4.794a5.107 5.107 0 0 1 .242-2.266c.358-.908.79-1.774 1.3-2.601l1.446-2.121a397.33 397.33 0 0 0 3.254-4.24Z"/></svg></div><span>Hono</span></div>
            <div class="tree-node" style="--delay: 1.02s"><div class="node-circle"><svg class="node-svg" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M5.353 11.823a1.036 1.036 0 0 0-.395-1.422 1.063 1.063 0 0 0-1.437.399L.138 16.702a1.035 1.035 0 0 0 .395 1.422 1.063 1.063 0 0 0 1.437-.398l3.383-5.903Zm11.216 0a1.036 1.036 0 0 0-.394-1.422 1.064 1.064 0 0 0-1.438.399l-3.382 5.902a1.036 1.036 0 0 0 .394 1.422c.506.283 1.15.104 1.438-.398l3.382-5.903Zm7.293-4.525a1.036 1.036 0 0 0-.395-1.422 1.062 1.062 0 0 0-1.437.399l-3.383 5.902a1.036 1.036 0 0 0 .395 1.422 1.063 1.063 0 0 0 1.437-.399l3.383-5.902Zm-11.219 0a1.035 1.035 0 0 0-.394-1.422 1.064 1.064 0 0 0-1.438.398l-3.382 5.903a1.036 1.036 0 0 0 .394 1.422c.506.282 1.15.104 1.438-.399l3.382-5.902Z"/></svg></div><span>Drizzle</span></div>
            <div class="tree-node" style="--delay: 1.09s"><div class="node-circle"><i class="devicon-flutter-plain colored"></i></div><span>Flutter</span></div>
            <div class="tree-node" style="--delay: 1.16s"><div class="node-circle"><i class="devicon-react-original colored"></i></div><span>React Native</span></div>
            <div class="tree-node" style="--delay: 1.23s"><div class="node-circle"><i class="devicon-capacitor-plain colored"></i></div><span>Capacitor</span></div>
            <div class="tree-node" style="--delay: 1.30s"><div class="node-circle"><svg class="node-svg" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M2.584 3.582a2.247 2.247 0 0 1 2.112-1.479h14.617c.948 0 1.794.595 2.115 1.487l2.44 6.777a2.248 2.248 0 0 1-.624 2.443l-9.61 8.52a2.247 2.247 0 0 1-2.963.018L.776 12.773a2.248 2.248 0 0 1-.64-2.467Zm12.038 4.887-9.11 5.537 5.74 5.007c.456.399 1.139.396 1.593-.006l5.643-5.001H14.4l6.239-3.957c.488-.328.69-.947.491-1.5l-1.24-3.446a1.535 1.535 0 0 0-1.456-1.015H5.545a1.535 1.535 0 0 0-1.431 1.01l-1.228 3.37z"/></svg></div><span>Zod</span></div>
            <div class="tree-node" style="--delay: 1.37s"><div class="node-circle"><svg class="node-svg" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M0 3.39v17.22h5.783V15.06h6.434V8.939H5.783V3.39ZM12.217 8.94h5.638v6.122h-5.638v5.548H24V3.391H12.217Z"/></svg></div><span>Better Auth</span></div>
          </div>
        </div>

        <div class="branch branch--ai" style="--branch-delay: 0.58s">
          <div class="branch-head">
            <span class="branch-node" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><circle cx="12" cy="4" r="2"/><circle cx="12" cy="20" r="2"/><circle cx="4" cy="12" r="2"/><circle cx="20" cy="12" r="2"/><line x1="12" y1="6" x2="12" y2="9"/><line x1="12" y1="15" x2="12" y2="18"/><line x1="6" y1="12" x2="9" y2="12"/><line x1="15" y1="12" x2="18" y2="12"/></svg>
            </span>
            <span class="branch-line"></span>
            <span class="branch-label">{t('home.skills.ai')}</span>
          </div>
          <div class="branch-nodes">
            <div class="tree-node" style="--delay: 0.88s"><div class="node-circle"><svg class="node-svg" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="m4.7144 15.9555 4.7174-2.6471.079-.2307-.079-.1275h-.2307l-.7893-.0486-2.6956-.0729-2.3375-.0971-2.2646-.1214-.5707-.1215-.5343-.7042.0546-.3522.4797-.3218.686.0608 1.5179.1032 2.2767.1578 1.6514.0972 2.4468.255h.3886l.0546-.1579-.1336-.0971-.1032-.0972L6.973 9.8356l-2.55-1.6879-1.3356-.9714-.7225-.4918-.3643-.4614-.1578-1.0078.6557-.7225.8803.0607.2246.0607.8925.686 1.9064 1.4754 2.4893 1.8336.3643.3035.1457-.1032.0182-.0728-.164-.2733-1.3539-2.4467-1.445-2.4893-.6435-1.032-.17-.6194c-.0607-.255-.1032-.4674-.1032-.7285L6.287.1335 6.6997 0l.9957.1336.419.3642.6192 1.4147 1.0018 2.2282 1.5543 3.0296.4553.8985.2429.8318.091.255h.1579v-.1457l.1275-1.706.2368-2.0947.2307-2.6957.0789-.7589.3764-.9107.7468-.4918.5828.2793.4797.686-.0668.4433-.2853 1.8517-.5586 2.9021-.3643 1.9429h.2125l.2429-.2429.9835-1.3053 1.6514-2.0643.7286-.8196.85-.9046.5464-.4311h1.0321l.759 1.1293-.34 1.1657-1.0625 1.3478-.8804 1.1414-1.2628 1.7-.7893 1.36.0729.1093.1882-.0183 2.8535-.607 1.5421-.2794 1.8396-.3157.8318.3886.091.3946-.3278.8075-1.967.4857-2.3072.4614-3.4364.8136-.0425.0304.0486.0607 1.5482.1457.6618.0364h1.621l3.0175.2247.7892.522.4736.6376-.079.4857-1.2142.6193-1.6393-.3886-3.825-.9107-1.3113-.3279h-.1822v.1093l1.0929 1.0686 2.0035 1.8092 2.5075 2.3314.1275.5768-.3218.4554-.34-.0486-2.2039-1.6575-.85-.7468-1.9246-1.621h-.1275v.17l.4432.6496 2.3436 3.5214.1214 1.0807-.17.3521-.6071.2125-.6679-.1214-1.3721-1.9246L14.38 17.959l-1.1414-1.9428-.1397.079-.674 7.2552-.3156.3703-.7286.2793-.6071-.4614-.3218-.7468.3218-1.4753.3886-1.9246.3157-1.53.2853-1.9004.17-.6314-.0121-.0425-.1397.0182-1.4328 1.9672-2.1796 2.9446-1.7243 1.8456-.4128.164-.7164-.3704.0667-.6618.4008-.5889 2.386-3.0357 1.4389-1.882.929-1.0868-.0062-.1579h-.0546l-6.3385 4.1164-1.1293.1457-.4857-.4554.0608-.7467.2307-.2429 1.9064-1.3114Z"/></svg></div><span>Claude Code</span></div>
            <div class="tree-node" style="--delay: 0.95s"><div class="node-circle"><svg class="node-svg" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22 24H2V0h20zM17 4.8H7v14.4h10z"/></svg></div><span>opencode</span></div>
            <div class="tree-node" style="--delay: 1.02s"><div class="node-circle"><svg class="node-svg node-svg--stroke" viewBox="0 0 180 180" xmlns="http://www.w3.org/2000/svg"><path d="M23.5996 85.2532L86.2021 22.6507C94.8457 14.0071 108.86 14.0071 117.503 22.6507C126.147 31.2942 126.147 45.3083 117.503 53.9519L70.2254 101.23" stroke-width="11.0667"/><path d="M70.8789 100.578L117.504 53.952C126.148 45.3083 140.163 45.3083 148.806 53.952L149.132 54.278C157.776 62.9216 157.776 76.9357 149.132 85.5792L92.5139 142.198C89.6327 145.079 89.6327 149.75 92.5139 152.631L104.14 164.257" stroke-width="11.0667"/><path d="M101.853 38.3013L55.553 84.6011C46.9094 93.2447 46.9094 107.258 55.553 115.902C64.1966 124.546 78.2106 124.546 86.8543 115.902L133.154 69.6025" stroke-width="11.0667"/></svg></div><span>MCP</span></div>
          </div>
        </div>

        <div class="branch branch--tools" style="--branch-delay: 0.72s">
          <div class="branch-head">
            <span class="branch-node" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
            </span>
            <span class="branch-line"></span>
            <span class="branch-label">{t('home.skills.tools')}</span>
          </div>
          <div class="branch-nodes">
            <div class="tree-node" style="--delay: 1.02s"><div class="node-circle"><i class="devicon-git-plain colored"></i></div><span>Git</span></div>
            <div class="tree-node" style="--delay: 1.09s"><div class="node-circle"><i class="devicon-docker-plain colored"></i></div><span>Docker</span></div>
            <div class="tree-node" style="--delay: 1.16s"><div class="node-circle"><i class="devicon-bun-plain colored"></i></div><span>Bun</span></div>
            <div class="tree-node" style="--delay: 1.23s"><div class="node-circle"><i class="devicon-vscode-plain colored"></i></div><span>VS Code</span></div>
            <div class="tree-node" style="--delay: 1.37s"><div class="node-circle"><i class="devicon-github-plain"></i></div><span>GitHub</span></div>
            <div class="tree-node" style="--delay: 1.44s"><div class="node-circle"><i class="devicon-gitlab-plain colored"></i></div><span>GitLab</span></div>
            <div class="tree-node" style="--delay: 1.51s"><div class="node-circle"><i class="devicon-linux-plain"></i></div><span>Linux</span></div>
            <div class="tree-node" style="--delay: 1.58s"><div class="node-circle"><i class="devicon-debian-plain colored"></i></div><span>Debian</span></div>
          </div>
        </div>

        <div class="branch branch--db" style="--branch-delay: 0.86s">
          <div class="branch-head">
            <span class="branch-node" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
            </span>
            <span class="branch-line"></span>
            <span class="branch-label">{t('home.skills.databases')}</span>
